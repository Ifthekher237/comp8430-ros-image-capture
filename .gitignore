# ============================================================
# .gitignore — phase3_robot_classifier
# ============================================================

# Model checkpoints (large files — do not commit)
outputs/models/*.pth
outputs/models/*.pt

# YOLO auto-downloaded weights
*.pt
yolov8*.pt
runs/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
env/
.env/
*.egg-info/

# macOS junk
.DS_Store
.AppleDouble
.LSOverride

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Output files (generated — do not commit)
outputs/logs/
outputs/plots/
outputs/predictions/

# Dataset splits (generated by scripts — do not commit)
../dataset/clean_dataset_split/
../dataset/robot_split/
../dataset/three_class_robot/
../dataset/three_class_final/
../dataset/_temp_three_class_source/

# IDE
.vscode/
.idea/
*.swp
*.swo

# ROS2 build artifacts (these live in the workspace, not here)
build/
install/
log/

# Logs
*.log